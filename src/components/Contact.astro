                    </div>
                </div>

                <div class="info-block">
                    <div class="info-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
                    </div>
                    <div>
                        <p class="info-label">Phone</p>
                        <a href="tel:+919967755831" class="info-value">+91 9967755831</a>
                    </div>
                </div>

                <div class="social-row">
                    <a href="https://www.linkedin.com/in/subodh-kamble-16a237168" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="LinkedIn">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                    </a>
                    <a href="https://github.com/tusuii" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="GitHub">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                    </a>
                    <a href="mailto:subodhkamble099@gmail.com" class="social-icon" aria-label="Email">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10h5v-2h-5c-4.34 0-8-3.66-8-8s3.66-8 8-8 8 3.66 8 8v1.43c0 .79-.71 1.57-1.5 1.57s-1.5-.78-1.5-1.57V12c0-2.76-2.24-5-5-5s-5 2.24-5 5 2.24 5 5 5c1.38 0 2.64-.56 3.54-1.47.65.89 1.77 1.47 2.96 1.47 1.97 0 3.5-1.6 3.5-3.57V12c0-5.52-4.48-10-10-10zm0 13c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3z"/></svg>
                    </a>
                    <a href="https://drive.google.com/file/d/18bc6bHaltH2kXa9HteNnYHtzVu2WkzgE/view?usp=sharing" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="Resume">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"/></svg>
                    </a>
                </div>
            </div>

            <form class="contact-form card" id="contact-form">
                <!-- Honeypot field — hidden from humans, bots fill it -->
                <div class="form-group" style="position:absolute;left:-9999px;top:-9999px;" aria-hidden="true">
                    <label for="website">Website</label>
                    <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
                </div>
                <div class="form-group">
                    <label for="name">Name</label>
                    <input type="text" id="name" name="name" placeholder="Your name" required maxlength="100" />
                </div>
                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" placeholder="your@email.com" required maxlength="150" />
                </div>
                <div class="form-group">
                    <label for="subject">Subject</label>
                    <input type="text" id="subject" name="subject" placeholder="What's this about?" maxlength="200" />
                </div>
                <div class="form-group">
                    <label for="message">Message</label>
                    <textarea id="message" name="message" rows="5" placeholder="Tell me about your project or just say hi..." required maxlength="2000"></textarea>
                </div>
                <button type="submit" class="submit-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                    <span class="btn-text">Send Message</span>
                </button>
                <p class="form-status" id="form-status"></p>
            </form>
        </div>
    </div>
</section>

<script>
import PocketBase from 'pocketbase';

const pb = new PocketBase(import.meta.env.PUBLIC_PB_URL || 'https://db.mrsubodh.xyz');

let lastSubmitTime = 0;
const RATE_LIMIT_MS = 30000; // 30 seconds between submissions

function sanitize(str: string): string {
    return str.trim().replace(/[<>]/g, '');
}

document.getElementById('contact-form')!.addEventListener('submit', async function(e) {
    e.preventDefault();

    const form = this as HTMLFormElement;
    const btn = form.querySelector('.submit-btn') as HTMLButtonElement;
    const btnText = btn.querySelector('.btn-text') as HTMLSpanElement;
    const status = document.getElementById('form-status')!;

    // Honeypot check — if filled, silently reject (bot detected)
    const honeypot = (form.querySelector('#website') as HTMLInputElement).value;
    if (honeypot) {
        status.textContent = 'Message sent successfully! I\'ll get back to you soon.';
        status.className = 'form-status success';
        form.reset();
        return;
    }

    // Rate limiting
    const now = Date.now();
    if (now - lastSubmitTime < RATE_LIMIT_MS) {
        const waitSec = Math.ceil((RATE_LIMIT_MS - (now - lastSubmitTime)) / 1000);
        status.textContent = `Please wait ${waitSec} seconds before sending another message.`;
        status.className = 'form-status error';
        return;
    }

    btn.disabled = true;
    btnText.textContent = 'Sending...';
    status.textContent = '';
    status.className = 'form-status';

    const data = {
        name: sanitize((form.querySelector('#name') as HTMLInputElement).value),
        email: sanitize((form.querySelector('#email') as HTMLInputElement).value),
        subject: sanitize((form.querySelector('#subject') as HTMLInputElement).value),
        message: sanitize((form.querySelector('#message') as HTMLTextAreaElement).value),
    };

    // Basic validation
    if (!data.name || !data.email || !data.message) {
        status.textContent = 'Please fill in all required fields.';
        status.className = 'form-status error';
        btn.disabled = false;
        btnText.textContent = 'Send Message';
        return;
    }

    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(data.email)) {
        status.textContent = 'Please enter a valid email address.';
        status.className = 'form-status error';
        btn.disabled = false;
        btnText.textContent = 'Send Message';
        return;
    }

    try {
        await pb.collection('contact_form').create(data);
        lastSubmitTime = Date.now();

        status.textContent = 'Message sent successfully! I\'ll get back to you soon.';
        status.className = 'form-status success';
        form.reset();
    } catch {
        status.textContent = 'Something went wrong. Please try again or email me directly.';
        status.className = 'form-status error';
    } finally {
        btn.disabled = false;
        btnText.textContent = 'Send Message';
    }
});
</script>

<style>
    h2 {
        font-size: 2.5rem;
        margin-bottom: 0.5rem;
        text-align: center;
        color: var(--text);
    }

    .section-tagline {
        text-align: center;
        color: var(--text);
        opacity: 0.7;
        font-size: 1.1rem;
        margin-bottom: 3rem;
    }

    .contact-layout {
        display: grid;
        grid-template-columns: 1fr 1.2fr;
        gap: 3rem;
        align-items: start;
        max-width: 900px;
        margin: 0 auto;
    }

    /* Left column — info */
    .contact-info-col {
        display: flex;
        flex-direction: column;
        gap: 1.75rem;
        padding-top: 1rem;
    }

    .info-block {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
    }

    .info-icon {
        width: 40px;
        height: 40px;
        border-radius: 0.5rem;
        background: rgba(59, 130, 246, 0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--accent);
        flex-shrink: 0;
    }

    .info-label {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--text);
        opacity: 0.6;
        margin: 0 0 0.15rem 0;
        font-weight: 600;
    }

    .info-value {
        font-size: 0.95rem;
        color: var(--text);
        margin: 0;
        text-decoration: none;
        transition: color 0.2s ease;
    }

    a.info-value:hover {
        color: var(--accent);
    }

    .social-row {
        display: flex;
        gap: 1rem;
        margin-top: 0.5rem;
    }

    .social-icon {
        width: 42px;
        height: 42px;
        border-radius: 0.5rem;
        background: rgba(59, 130, 246, 0.08);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text);
        transition: all 0.2s ease;
    }

    .social-icon:hover {
        background: var(--accent);
        color: white;
        transform: translateY(-2px);
    }

    /* Right column — form */
    .contact-form {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
    }

    .form-group label {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--text);
    }

    .form-group input,
    .form-group textarea {
        width: 100%;
        padding: 0.7rem 0.9rem;
        border: 1.5px solid rgba(59, 130, 246, 0.15);
        border-radius: 0.5rem;
        background: var(--background);
        color: var(--text);
        font-family: 'Inter', system-ui, sans-serif;
        font-size: 0.95rem;
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
        box-sizing: border-box;
    }

    .form-group input::placeholder,
    .form-group textarea::placeholder {
        color: var(--text);
        opacity: 0.4;
    }

    .form-group input:focus,
    .form-group textarea:focus {
        outline: none;
        border-color: var(--accent);
        box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
    }

    .form-group textarea {
        resize: vertical;
        min-height: 120px;
    }

    .submit-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        background: var(--accent);
        color: white;
        border: none;
        border-radius: 0.5rem;
        font-family: 'Inter', system-ui, sans-serif;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        margin-top: 0.25rem;
    }

    .submit-btn:hover {
        background: var(--accent-light);
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
    }

    .submit-btn:active {
        transform: translateY(0);
    }

    .submit-btn:disabled {
        opacity: 0.7;
        cursor: not-allowed;
        transform: none;
    }

    .form-status {
        margin: 0;
        font-size: 0.9rem;
        font-weight: 500;
        min-height: 1.4em;
    }

    .form-status.success {
        color: #16a34a;
    }

    .form-status.error {
        color: #dc2626;
    }

    @media (max-width: 768px) {
        .contact-layout {
            grid-template-columns: 1fr;
            gap: 2rem;
        }

        .contact-info-col {
            padding-top: 0;
        }

        .social-row {
            justify-content: center;
        }

        h2 {
            font-size: 2rem;
        }
    }
</style>
