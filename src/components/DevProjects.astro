<style>
    h2 {
        font-size: 2.5rem;
        margin-bottom: 0.5rem;
        text-align: center;
        color: var(--text);
    }

    .section-description {
        text-align: center;
        color: var(--text);
        opacity: 0.7;
        font-size: 1.1rem;
        margin-bottom: 2.5rem;
    }

    .spline-wrapper {
        border-radius: 1rem;
        overflow: hidden;
        margin-bottom: 3rem;
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);
        border: 1px solid rgba(59, 130, 246, 0.15);
    }

    .spline-wrapper iframe {
        display: block;
    }

    .dev-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
        gap: 2rem;
    }

    .dev-card {
        text-decoration: none;
        color: inherit;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        padding: 0;
        border-radius: 0.5rem;
    }

    .dev-card:hover {
        transform: translateY(-2px);
    }

    .card-image-link {
        display: block;
        text-decoration: none;
    }

    .card-image {
        width: 100%;
        height: 180px;
        overflow: hidden;
        background: linear-gradient(135deg, var(--gradient-1), var(--gradient-2));
    }

    .card-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s ease;
    }

    .dev-card:hover .card-image img {
        transform: scale(1.05);
    }

    .card-content {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        flex: 1;
    }

    .card-content h4 {
        font-size: 1.35rem;
        margin: 0 0 0.4rem 0;
        color: var(--accent);
    }

    .dev-tech {
        font-size: 0.8rem;
        color: var(--accent);
        opacity: 0.85;
        margin: 0 0 1rem 0;
        line-height: 1.5;
    }

    .dev-desc {
        font-size: 0.9rem;
        line-height: 1.6;
        color: var(--text);
        opacity: 0.8;
        margin: 0 0 1.25rem 0;
        flex: 1;
    }

    .card-links {
        display: flex;
        gap: 0.75rem;
        margin-top: auto;
    }

    .link-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.4rem 0.85rem;
        border-radius: 0.375rem;
        font-size: 0.8rem;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s ease;
    }

    .github-btn {
        background: var(--text);
        color: white;
    }

    .github-btn:hover {
        background: #000;
        transform: translateY(-1px);
    }

    .live-btn {
        background: var(--accent);
        color: white;
    }

    .live-btn:hover {
        background: var(--accent-light);
        transform: translateY(-1px);
    }

    @media (max-width: 768px) {
        .dev-grid {
            grid-template-columns: 1fr;
        }

        .spline-wrapper iframe {
            height: 250px;
        }
    }
</style>
